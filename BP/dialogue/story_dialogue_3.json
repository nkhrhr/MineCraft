        ]
      },
      {
        "scene_tag": "ending",
        "npc_name": "案内人",
        "text": "おめでとう、勇者よ！\n\nお前は世界を闇から救った。この物語は永遠に語り継がれるだろう...",
        "buttons": [
          {
            "name": "物語を終える",
            "commands": [
              "/title @p title §6§lおめでとう！",
              "/title @p subtitle §r物語完結",
              "/playsound ui.toast.challenge_complete @p",
              "/tag @p add story_complete"
            ]
          }
        ]
      }
    ]
  }
