{
  "format_version": "1.20.0",
  "minecraft:entity": {
    "description": {
      "identifier": "story:npc_guide",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "story_chapter_1": {
        "minecraft:variant": {
          "value": 0
        }
      },
      "story_chapter_2": {
        "minecraft:variant": {
          "value": 1
        }
      }
    },
    "components": {
      "minecraft:type_family": {
        "family": ["npc", "story_character"]
      },
      "minecraft:collision_box": {
        "width": 0.6,
        "height": 1.8
      },
      "minecraft:health": {
        "value": 20,
        "max": 20
      },
      "minecraft:damage_sensor": {
        "triggers": {
          "cause": "all",
          "deals_damage": false
        }
      },
      "minecraft:physics": {
        "has_gravity": true,
        "has_collision": true
      },
      "minecraft:pushable": {
        "is_pushable": false,
        "is_pushable_by_piston": false
      },
      "minecraft:nameable": {
        "always_show": true,
        "allow_name_tag_renaming": false,
        "default_trigger": {
          "event": "story:dialogue_start"
        }
      }
    },
    "events": {
      "story:dialogue_start": {
        "sequence": [
          {
            "queue_command": {
              "command": "dialogue open @s @p story_dialogue_1"
            }
          }
        ]
      },
      "story:progress_chapter": {
        "add": {
          "component_groups": ["story_chapter_2"]
        },
        "remove": {
          "component_groups": ["story_chapter_1"]
        }
      }
    }
  }
}
