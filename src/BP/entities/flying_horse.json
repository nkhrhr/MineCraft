{
  "format_version": "1.20.0",
  "minecraft:entity": {
    "description": {
      "identifier": "story:flying_horse",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "story:flying": {
        "minecraft:can_fly": {},
        "minecraft:movement": {
          "value": 0.35
        }
      },
      "story:saddled": {
        "minecraft:is_saddled": {},
        "minecraft:rideable": {
          "seat_count": 1,
          "family_types": [
            "player"
          ],
          "seats": {
            "position": [0.0, 0.9, -0.2]
          }
        }
      }
    },
    "components": {
      "minecraft:type_family": {
        "family": ["flying_horse", "mob"]
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0,
        "breathes_air": true,
        "breathes_water": false
      },
      "minecraft:collision_box": {
        "width": 1.3,
        "height": 1.6
      },
      "minecraft:health": {
        "value": 30,
        "max": 30
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:movement": {
        "value": 0.25
      },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_fly": {},
      "minecraft:interact": {
        "interactions": [
          {
            "on_interact": {
              "filters": {
                "all_of": [
                  {
                    "test": "is_family",
                    "subject": "other",
                    "value": "player"
                  },
                  {
                    "test": "has_component",
                    "subject": "self",
                    "operator": "!=",
                    "value": "minecraft:is_saddled"
                  }
                ]
              },
              "event": "story:on_saddled"
            },
            "use_item": false,
            "interact_text": "action.interact.ride"
          }
        ]
      },
      "minecraft:physics": {
        "has_gravity": false
      },
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },
      "minecraft:conditional_bandwidth_optimization": {}
    },
    "events": {
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": [
            "story:flying",
            "story:saddled"
          ]
        }
      },
      "story:on_saddled": {
        "add": {
          "component_groups": [
            "story:saddled"
          ]
        }
      }
    }
  }
}
