        "height_adjustment_chance": 0.002,
        "goal_radius": 8.0,
        "angle_change": 15.0,
        "radius_range": [5.0, 15.0],
        "height_range": [1.0, 10.0],
        "height_above_target_range": [10.0, 40.0]
      },
